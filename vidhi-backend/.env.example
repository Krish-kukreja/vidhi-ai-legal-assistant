# ─────────────────────────────────────────────────────────────────────────────
# VIDHI Backend — Environment Variables Template
# Copy this file to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════
# AWS CREDENTIALS (Required)
# ══════════════════════════════
# Get these from AWS Console > IAM > Users > Security credentials
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# ══════════════════════════════
# AWS S3 BUCKETS (Required)
# ══════════════════════════════
# Create these buckets in your AWS account (same region as above)
S3_BUCKET_DOCUMENTS=your-vidhi-documents-bucket
S3_BUCKET_AUDIO=your-vidhi-audio-bucket

# ══════════════════════════════
# AWS DYNAMODB TABLES (Required)
# ══════════════════════════════
# These will be auto-created by the app or you can create manually
DYNAMODB_TABLE_USERS=vidhi-users
DYNAMODB_TABLE_CHAT=vidhi-chat-history
DYNAMODB_TABLE_CACHE=vidhi-response-cache
DYNAMODB_TABLE_EMBEDDING_CACHE=vidhi-embedding-cache

# ══════════════════════════════
# AWS BEDROCK MODELS (Required)
# ══════════════════════════════
# Make sure you have access to these models in AWS Bedrock
# Request access at: AWS Console > Bedrock > Model access
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MODEL_ID_ADVANCED=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBEDDINGS_MODEL=amazon.titan-embed-text-v2:0

# ══════════════════════════════
# FEATURE FLAGS
# ══════════════════════════════
ENABLE_VOICE_INPUT=True
ENABLE_DOCUMENT_ANALYSIS=True
ENABLE_SCHEME_MATCHING=True
ENABLE_CACHING=True

# ══════════════════════════════
# BHASHINI (Optional)
# ══════════════════════════════
# For regional Indian language support (dialects not covered by AWS Polly)
# Register at: https://bhashini.gov.in/
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_API_KEY_ULCA=

# ══════════════════════════════
# MISC
# ══════════════════════════════
START_WEB_SCRAPING=False
LOG_LEVEL=INFO
LOG_FORMAT=json
ENVIRONMENT=development

# ══════════════════════════════
# AUTHENTICATION & SECURITY
# ══════════════════════════════
# JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-this-secret-key-in-production-use-random-string

# API Keys for service-to-service authentication (comma-separated)
# Generate with: python -c "import secrets; print(f'vidhi_{secrets.token_urlsafe(32)}')"
API_KEYS=

# ══════════════════════════════
# RATE LIMITING
# ══════════════════════════════
# Rate limits are configured in middleware/rate_limit_middleware.py
# Default: 100 req/min for registered users, 20 req/min for guests
# Adjust RATE_LIMITS dict in the middleware file if needed

# ══════════════════════════════
# ERROR HANDLING & LOGGING
# ══════════════════════════════
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_FORMAT: json (structured) or text (human-readable)
# ENVIRONMENT: development (shows tracebacks) or production (hides tracebacks)

# ══════════════════════════════
# MONITORING (Optional)
# ══════════════════════════════
# Sentry DSN for error tracking and performance monitoring
# Get from: https://sentry.io/ (create account and project)
# Leave empty to disable monitoring
SENTRY_DSN=

# Release version for tracking deployments
RELEASE_VERSION=1.0.0

# ══════════════════════════════
# CACHING (Optional)
# ══════════════════════════════
# Cache configuration (uses defaults if not set)
# CACHE_MAX_SIZE: Maximum number of cache entries (default: 1000)
# CACHE_DEFAULT_TTL: Default TTL in seconds (default: 3600 = 1 hour)
# CACHE_MAX_SIZE=1000
# CACHE_DEFAULT_TTL=3600

# ══════════════════════════════
# DATA REFRESH SCHEDULER (Optional)
# ══════════════════════════════
# Scheduler runs automatically on startup
# Daily incremental refresh: 2 AM
# Weekly full refresh: Sunday 3 AM
# No configuration needed - controlled via API endpoints

# ══════════════════════════════
# PHASE 1: HYBRID SEARCH & AGENTIC WORKFLOWS
# ══════════════════════════════
# Enable hybrid search (BM25 + Semantic + Reranking)
ENABLE_HYBRID_SEARCH=True
BM25_WEIGHT=0.5
SEMANTIC_WEIGHT=0.5
HYBRID_TOP_K=50

# Enable cross-encoder reranking
ENABLE_RERANKING=True
RERANKING_TOP_K=10
RERANKING_CONFIDENCE_THRESHOLD=0.0

# Enable LangGraph agentic workflows
ENABLE_AGENT=False
AGENT_MAX_ITERATIONS=5
AGENT_TIMEOUT=30

# Enable query expansion
ENABLE_QUERY_EXPANSION=False
QUERY_EXPANSION_CACHE_TTL=86400
