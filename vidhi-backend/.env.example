# ─────────────────────────────────────────────────────────────────────────────
# VIDHI Backend — Environment Variables Template
# Copy this file to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════
# AWS CREDENTIALS (Required)
# ══════════════════════════════
# Get these from AWS Console > IAM > Users > Security credentials
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# ══════════════════════════════
# AWS S3 BUCKETS (Required)
# ══════════════════════════════
# Create these buckets in your AWS account (same region as above)
S3_BUCKET_DOCUMENTS=your-vidhi-documents-bucket
S3_BUCKET_AUDIO=your-vidhi-audio-bucket

# ══════════════════════════════
# AWS DYNAMODB TABLES (Required)
# ══════════════════════════════
# These will be auto-created by the app or you can create manually
DYNAMODB_TABLE_USERS=vidhi-users
DYNAMODB_TABLE_CHAT=vidhi-chat-history
DYNAMODB_TABLE_CACHE=vidhi-response-cache
DYNAMODB_TABLE_EMBEDDING_CACHE=vidhi-embedding-cache

# ══════════════════════════════
# AWS BEDROCK MODELS (Required)
# ══════════════════════════════
# Make sure you have access to these models in AWS Bedrock
# Request access at: AWS Console > Bedrock > Model access
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MODEL_ID_ADVANCED=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBEDDINGS_MODEL=amazon.titan-embed-text-v2:0

# ══════════════════════════════
# FEATURE FLAGS
# ══════════════════════════════
ENABLE_VOICE_INPUT=True
ENABLE_DOCUMENT_ANALYSIS=True
ENABLE_SCHEME_MATCHING=True
ENABLE_CACHING=True

# ══════════════════════════════
# BHASHINI (Optional)
# ══════════════════════════════
# For regional Indian language support (dialects not covered by AWS Polly)
# Register at: https://bhashini.gov.in/
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_API_KEY_ULCA=

# ══════════════════════════════
# MISC
# ══════════════════════════════
START_WEB_SCRAPING=False
LOG_LEVEL=INFO
